# =============================================================
# swing-trade-system 環境変数テンプレート
# このファイルをコピーして .env にリネームして使用してください。
# .env は .gitignore で除外されています（絶対にコミットしないこと）
# =============================================================

# ─────────────────────────────────────────────────────────────
# J-Quants API（必須）
# https://jpx-jquants.com/ でアカウント作成後に取得
# Standardプラン以上が必要（Freeプランは過去2年分のみ）
# ─────────────────────────────────────────────────────────────
JQUANTS_REFRESH_TOKEN=your_jquants_refresh_token_here

# ─────────────────────────────────────────────────────────────
# kabuステーション® API（Phase 5 実取引用）
# 三菱UFJ eスマート証券の口座開設後に設定
# ─────────────────────────────────────────────────────────────
KABU_TRADE_PASSWORD=your_kabu_trade_password_here
KABU_API_PORT=18080

# ─────────────────────────────────────────────────────────────
# 取引モード
# Phase 4（ペーパートレード）: false のまま
# Phase 5（実取引）: true に変更
# ─────────────────────────────────────────────────────────────
LIVE_TRADING=false

# ─────────────────────────────────────────────────────────────
# Phase 5 資金設定
# 初期少額運用: 500000（50万円）
# 将来フル運用: 1000000（100万円）
# ─────────────────────────────────────────────────────────────
PHASE5_MAX_CAPITAL=500000

# ─────────────────────────────────────────────────────────────
# 配当落ちフィルター（Phase 5 で有効化）
# IS分析でExDate前3日の勝率が-33ptと判明（2026-05-03）
# Phase 4 は false（凍結ルール）
# Phase 5 移行時に true に変更する
# ─────────────────────────────────────────────────────────────
DIVIDEND_FILTER=false

# ─────────────────────────────────────────────────────────────
# ntfy プッシュ通知（スマホ通知）
# https://ntfy.sh/ でトピックを作成
# ─────────────────────────────────────────────────────────────
NTFY_TOPIC=swing-trade-moshaj-2026
